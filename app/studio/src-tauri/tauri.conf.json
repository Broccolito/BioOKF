{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BioOKF Studio",
  "version": "0.1.0",
  "identifier": "com.biookf.studio",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BioOKF Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 26 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
